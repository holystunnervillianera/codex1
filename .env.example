# Supabase project settings
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_ACCESS_TOKEN=USER_JWT_OR_SESSION_ACCESS_TOKEN
SUPABASE_RAW_BUCKET=vault-raw

# 32 random bytes, base64 encoded. Generate with: openssl rand -base64 32
VAULT_MASTER_KEY_B64=REPLACE_WITH_LOCAL_ONLY_SECRET

# Optional: newline-delimited JSONL log written locally for offline recovery.
VAULT_LOCAL_AUDIT_LOG=./vault-audit-local.jsonl
